# Local mock mode for testing the HTTP wrapper without model credentials.
PI_MOCK=1

# pi runtime args. The server removes --no-session and adds a session-specific
# --session-dir when handling invocations.
PI_ARGS=--mode rpc --no-session
REQUEST_TIMEOUT_MS=300000
ENABLE_DIAGNOSTICS=0

# Foundry OpenAI-compatible endpoint used to generate pi's custom foundry provider.
PI_OPENAI_BASE_URL=https://zihch-test-wus3-resource.services.ai.azure.com/openai/v1
PI_OPENAI_MODEL=gpt-5.4-mini
# PI_OPENAI_API_KEY=

# Optional artifact publishing to Azure Storage Static Website ($web container).
# Uploads use Entra ID / Managed Identity, not storage account keys.
ARTIFACT_PUBLISH_MODE=disabled
# ARTIFACT_STORAGE_ACCOUNT=
# ARTIFACT_STATIC_WEB_ENDPOINT=https://<account>.<zone>.web.core.windows.net
ARTIFACT_STATIC_WEB_CONTAINER=$web
ARTIFACT_BLOB_PREFIX=pi-foundry

# Real model credentials, depending on your pi model/provider config.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
